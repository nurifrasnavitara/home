<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Mrs. Nuri Frasna Vitara | English Teacher - SMP Muhammadiyah 9 Nagreg</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Fredoka:wght@400;500;600;700&family=Poppins:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&display=swap" rel="stylesheet">
<style>
  :root{
    --cream:#FFF8EE;
    --honey:#FFC94A;
    --coral:#FF8C7A;
    --mint:#A9DFC9;
    --sky:#9FD8E8;
    --navy:#27314F;
    --navy-soft:#4A5578;
    --gold:#E8A93C;
    --white:#FFFFFF;
    --radius-lg:28px;
    --radius-md:18px;
    --shadow-soft:0 18px 40px -18px rgba(39,49,79,0.25);
    --font-display:'Fredoka',sans-serif;
    --font-body:'Poppins',sans-serif;
  }

  *{margin:0;padding:0;box-sizing:border-box;}

  html{scroll-behavior:smooth;}

  body{
    font-family:var(--font-body);
    color:var(--navy);
    background:var(--cream);
    overflow-x:hidden;
  }

  /* ====== DECOR BLOBS ====== */
  .blob{
    position:absolute;
    border-radius:50%;
    filter:blur(0px);
    z-index:0;
    opacity:0.6;
  }

  /* ====== NAVBAR ====== */
  header{
    position:fixed;
    top:0;left:0;right:0;
    z-index:1000;
    background:rgba(255,248,238,0.85);
    backdrop-filter:blur(10px);
    border-bottom:1px solid rgba(39,49,79,0.06);
    transition:all 0.3s ease;
  }
  .nav-wrap{
    max-width:1180px;
    margin:0 auto;
    display:flex;
    align-items:center;
    justify-content:space-between;
    padding:14px 28px;
  }
  .brand{
    display:flex;
    align-items:center;
    gap:12px;
    font-family:var(--font-display);
    font-weight:600;
    font-size:1.05rem;
    color:var(--navy);
  }
  .brand img{
    height:42px;
    width:42px;
    object-fit:contain;
    border-radius:10px;
    background:var(--white);
    padding:4px;
    box-shadow:0 4px 12px rgba(39,49,79,0.12);
  }
  .brand small{
    display:block;
    font-family:var(--font-body);
    font-weight:400;
    font-size:0.68rem;
    color:var(--navy-soft);
    letter-spacing:0.04em;
  }
  nav ul{
    display:flex;
    gap:28px;
    list-style:none;
  }
  nav a{
    text-decoration:none;
    color:var(--navy-soft);
    font-weight:500;
    font-size:0.92rem;
    position:relative;
    transition:color 0.25s ease;
  }
  nav a::after{
    content:'';
    position:absolute;
    left:0;bottom:-6px;
    width:0;height:3px;
    border-radius:3px;
    background:var(--coral);
    transition:width 0.3s ease;
  }
  nav a:hover{color:var(--navy);}
  nav a:hover::after{width:100%;}

  .nav-cta{
    background:var(--navy);
    color:var(--cream);
    padding:10px 22px;
    border-radius:999px;
    font-weight:600;
    font-size:0.88rem;
    text-decoration:none;
    transition:transform 0.25s ease, background 0.25s ease;
    box-shadow:0 8px 20px -8px rgba(39,49,79,0.4);
  }
  .nav-cta:hover{
    background:var(--coral);
    transform:translateY(-2px);
  }

  /* ====== MOBILE NAV OVERLAY ====== */
  .mobile-nav{
    position:fixed;
    top:0; right:0;
    width:78%;
    max-width:320px;
    height:100vh;
    background:var(--white);
    z-index:1100;
    transform:translateX(100%);
    transition:transform 0.35s ease;
    box-shadow:-20px 0 50px -20px rgba(39,49,79,0.3);
    display:flex;
    flex-direction:column;
    padding:100px 32px 40px;
  }
  .mobile-nav.open{transform:translateX(0);}
  .mobile-nav a{
    text-decoration:none;
    color:var(--navy);
    font-family:var(--font-display);
    font-weight:600;
    font-size:1.25rem;
    padding:16px 0;
    border-bottom:1px solid rgba(39,49,79,0.06);
    display:flex;
    align-items:center;
    gap:10px;
  }
  .mobile-nav .nav-cta{
    display:inline-flex;
    justify-content:center;
    margin-top:24px;
  }
  .nav-backdrop{
    position:fixed;
    inset:0;
    background:rgba(39,49,79,0.4);
    z-index:1050;
    opacity:0;
    visibility:hidden;
    transition:opacity 0.35s ease;
  }
  .nav-backdrop.open{
    opacity:1;
    visibility:visible;
  }

  .nav-toggle{
    display:none;
    background:none;
    border:none;
    cursor:pointer;
    width:42px;height:42px;
    border-radius:12px;
    flex-direction:column;
    align-items:center;
    justify-content:center;
    gap:5px;
    background:var(--white);
    box-shadow:var(--shadow-soft);
    flex-shrink:0;
  }
  .nav-toggle span{
    display:block;
    width:20px;height:2.5px;
    border-radius:2px;
    background:var(--navy);
    transition:transform 0.3s ease, opacity 0.3s ease;
  }
  .nav-toggle.active span:nth-child(1){transform:translateY(7.5px) rotate(45deg);}
  .nav-toggle.active span:nth-child(2){opacity:0;}
  .nav-toggle.active span:nth-child(3){transform:translateY(-7.5px) rotate(-45deg);}

  /* ====== HERO ====== */
  .hero{
    position:relative;
    min-height:100vh;
    display:flex;
    align-items:center;
    padding:120px 28px 80px;
    overflow:hidden;
  }
  .hero .blob.b1{
    width:520px;height:520px;
    background:var(--honey);
    top:-180px;right:-160px;
    opacity:0.45;
  }
  .hero .blob.b2{
    width:380px;height:380px;
    background:var(--mint);
    bottom:-140px;left:-120px;
    opacity:0.55;
  }
  .hero .blob.b3{
    width:160px;height:160px;
    background:var(--sky);
    top:18%;left:8%;
    opacity:0.45;
  }
  .hero-inner{
    position:relative;
    z-index:2;
    max-width:1180px;
    margin:0 auto;
    display:grid;
    grid-template-columns:1.15fr 0.85fr;
    gap:56px;
    align-items:center;
    width:100%;
  }
  .eyebrow{
    display:inline-flex;
    align-items:center;
    gap:8px;
    background:var(--white);
    color:var(--coral);
    font-weight:600;
    font-size:0.8rem;
    letter-spacing:0.08em;
    text-transform:uppercase;
    padding:8px 18px;
    border-radius:999px;
    box-shadow:var(--shadow-soft);
    margin-bottom:22px;
    opacity:0;
    animation:fadeUp 0.8s ease forwards;
    animation-delay:0.1s;
  }
  .hero h1{
    font-family:var(--font-display);
    font-size:clamp(2.6rem, 5.2vw, 4.2rem);
    line-height:1.08;
    font-weight:700;
    color:var(--navy);
    margin-bottom:18px;
    opacity:0;
    animation:fadeUp 0.8s ease forwards;
    animation-delay:0.25s;
  }
  .hero h1 span{
    color:var(--coral);
    position:relative;
    white-space:nowrap;
  }
  .hero h1 span svg{
    position:absolute;
    left:-4%;
    bottom:-10px;
    width:108%;
  }
  .hero p.lead{
    font-size:1.08rem;
    color:var(--navy-soft);
    max-width:480px;
    margin-bottom:34px;
    line-height:1.7;
    opacity:0;
    animation:fadeUp 0.8s ease forwards;
    animation-delay:0.4s;
  }
  .hero-buttons{
    display:flex;
    gap:14px;
    flex-wrap:wrap;
    opacity:0;
    animation:fadeUp 0.8s ease forwards;
    animation-delay:0.55s;
  }
  .btn{
    padding:15px 30px;
    border-radius:999px;
    font-weight:600;
    font-size:0.95rem;
    text-decoration:none;
    display:inline-flex;
    align-items:center;
    gap:8px;
    transition:transform 0.25s ease, box-shadow 0.25s ease;
  }
  .btn-primary{
    background:var(--coral);
    color:var(--white);
    box-shadow:0 14px 30px -12px rgba(255,140,122,0.7);
  }
  .btn-primary:hover{transform:translateY(-3px); box-shadow:0 18px 36px -12px rgba(255,140,122,0.8);}
  .btn-secondary{
    background:var(--white);
    color:var(--navy);
    box-shadow:var(--shadow-soft);
  }
  .btn-secondary:hover{transform:translateY(-3px);}

  /* portrait */
  .hero-portrait{
    position:relative;
    display:flex;
    justify-content:center;
    align-items:center;
    opacity:0;
    animation:fadeIn 1s ease forwards;
    animation-delay:0.3s;
  }
  .portrait-frame{
    position:relative;
    width:min(360px, 80vw);
    aspect-ratio:1/1.08;
    border-radius:38% 62% 60% 40% / 48% 42% 58% 52%;
    overflow:hidden;
    box-shadow:var(--shadow-soft);
    border:6px solid var(--white);
    animation:morph 12s ease-in-out infinite;
  }
  .portrait-frame img{
    width:100%;height:100%;
    object-fit:cover;
    display:block;
  }
  @keyframes morph{
    0%,100%{border-radius:38% 62% 60% 40% / 48% 42% 58% 52%;}
    50%{border-radius:54% 46% 38% 62% / 40% 58% 42% 60%;}
  }
  .floating-tag{
    position:absolute;
    background:var(--white);
    padding:10px 18px;
    border-radius:14px;
    box-shadow:var(--shadow-soft);
    font-family:var(--font-display);
    font-weight:600;
    font-size:0.92rem;
    color:var(--navy);
    display:flex;
    align-items:center;
    gap:8px;
    animation:floaty 4.5s ease-in-out infinite;
  }
  .floating-tag.tag1{ top:6%; left:-6%; animation-delay:0s;}
  .floating-tag.tag2{ bottom:10%; right:-8%; animation-delay:1.2s; background:var(--navy); color:var(--cream);}
  .floating-tag.tag3{ top:46%; right:-12%; animation-delay:2.4s;}
  @keyframes floaty{
    0%,100%{transform:translateY(0px);}
    50%{transform:translateY(-12px);}
  }
  @keyframes fadeUp{
    from{opacity:0; transform:translateY(24px);}
    to{opacity:1; transform:translateY(0);}
  }
  @keyframes fadeIn{
    from{opacity:0;}
    to{opacity:1;}
  }

  /* ====== SECTION GENERAL ====== */
  section{
    position:relative;
    padding:90px 28px;
    max-width:1180px;
    margin:0 auto;
  }
  .section-tag{
    display:inline-block;
    font-family:var(--font-display);
    font-weight:600;
    font-size:0.8rem;
    letter-spacing:0.12em;
    text-transform:uppercase;
    color:var(--gold);
    background:rgba(232,169,60,0.12);
    padding:6px 16px;
    border-radius:999px;
    margin-bottom:14px;
  }
  .section-title{
    font-family:var(--font-display);
    font-size:clamp(1.8rem, 3.4vw, 2.6rem);
    font-weight:700;
    color:var(--navy);
    margin-bottom:14px;
    max-width:640px;
  }
  .section-desc{
    color:var(--navy-soft);
    max-width:600px;
    line-height:1.7;
    font-size:1rem;
  }
  .reveal{
    opacity:0;
    transform:translateY(30px);
    transition:opacity 0.7s ease, transform 0.7s ease;
  }
  .reveal.show{
    opacity:1;
    transform:translateY(0);
  }

  /* ====== ABOUT ====== */
  .about{
    background:var(--white);
    border-radius:var(--radius-lg);
    box-shadow:var(--shadow-soft);
    padding:60px;
    display:grid;
    grid-template-columns:0.9fr 1.1fr;
    gap:50px;
    align-items:center;
    position:relative;
    overflow:hidden;
  }
  .about::before{
    content:'';
    position:absolute;
    top:-60px;right:-60px;
    width:200px;height:200px;
    background:var(--mint);
    border-radius:50%;
    opacity:0.35;
  }
  .about-photo{
    position:relative;
    border-radius:var(--radius-md);
    overflow:hidden;
    aspect-ratio:4/5;
    box-shadow:0 20px 40px -20px rgba(39,49,79,0.3);
  }
  .about-photo img{width:100%;height:100%;object-fit:cover;display:block;}
  .about-text h3{
    font-family:var(--font-display);
    font-size:1.6rem;
    margin-bottom:6px;
    color:var(--navy);
  }
  .about-text .role{
    color:var(--coral);
    font-weight:600;
    margin-bottom:18px;
    font-size:0.95rem;
  }
  .about-text p{
    color:var(--navy-soft);
    line-height:1.8;
    margin-bottom:14px;
  }
  .about-stats{
    display:flex;
    gap:28px;
    margin-top:24px;
    flex-wrap:wrap;
  }
  .about-stats div{
    background:var(--cream);
    border-radius:16px;
    padding:14px 20px;
    text-align:center;
    min-width:110px;
  }
  .about-stats strong{
    font-family:var(--font-display);
    font-size:1.5rem;
    color:var(--navy);
    display:block;
  }
  .about-stats span{
    font-size:0.78rem;
    color:var(--navy-soft);
  }

  /* ====== METHODS ====== */
  .method-grid{
    display:grid;
    grid-template-columns:repeat(4, 1fr);
    gap:22px;
    margin-top:46px;
  }
  .method-card{
    background:var(--white);
    border-radius:var(--radius-md);
    padding:30px 24px;
    box-shadow:var(--shadow-soft);
    transition:transform 0.3s ease, box-shadow 0.3s ease;
    border-top:4px solid var(--honey);
  }
  .method-card:nth-child(2){border-top-color:var(--coral);}
  .method-card:nth-child(3){border-top-color:var(--sky);}
  .method-card:nth-child(4){border-top-color:var(--mint);}
  .method-card:hover{
    transform:translateY(-8px);
    box-shadow:0 24px 50px -22px rgba(39,49,79,0.3);
  }
  .method-icon{
    width:54px;height:54px;
    border-radius:14px;
    display:flex;align-items:center;justify-content:center;
    margin-bottom:18px;
    background:var(--cream);
    font-size:1.6rem;
  }
  .method-card h4{
    font-family:var(--font-display);
    font-size:1.1rem;
    margin-bottom:8px;
    color:var(--navy);
  }
  .method-card p{
    color:var(--navy-soft);
    font-size:0.92rem;
    line-height:1.65;
  }

  /* ====== MATERI / KELAS ====== */
  .class-grid{
    display:grid;
    grid-template-columns:repeat(3, 1fr);
    gap:24px;
    margin-top:46px;
  }
  .class-card{
    position:relative;
    border-radius:var(--radius-md);
    padding:34px 28px;
    color:var(--white);
    overflow:hidden;
    min-height:230px;
    display:flex;
    flex-direction:column;
    justify-content:space-between;
    box-shadow:var(--shadow-soft);
  }
  .class-card.c1{background:linear-gradient(145deg, #FF8C7A, #FFB199);}
  .class-card.c2{background:linear-gradient(145deg, #4A5578, #27314F);}
  .class-card.c3{background:linear-gradient(145deg, #5BC0B7, #9FD8E8);}
  .class-card .grade{
    font-family:var(--font-display);
    font-size:2.6rem;
    font-weight:700;
    opacity:0.85;
  }
  .class-card h4{
    font-family:var(--font-display);
    font-size:1.25rem;
    margin-bottom:8px;
  }
  .class-card p{
    font-size:0.9rem;
    opacity:0.92;
    line-height:1.6;
  }
  .class-card ul{
    list-style:none;
    margin-top:10px;
    font-size:0.86rem;
    opacity:0.95;
    line-height:1.9;
  }
  .class-card ul li::before{
    content:'✦ ';
  }

  /* ====== GALERI ====== */
  .gallery-grid{
    display:grid;
    grid-template-columns:repeat(4, 1fr);
    grid-template-rows:repeat(2, 160px);
    gap:18px;
    margin-top:46px;
  }
  .gallery-grid .g-item{
    border-radius:var(--radius-md);
    overflow:hidden;
    position:relative;
    box-shadow:var(--shadow-soft);
  }
  .gallery-grid .g-item img{
    width:100%;height:100%;object-fit:cover;display:block;
    transition:transform 0.5s ease;
  }
  .gallery-grid .g-item:hover img{transform:scale(1.08);}
  .gallery-grid .g1{grid-column:1/3; grid-row:1/3;}
  .gallery-grid .g2{grid-column:3/5; grid-row:1/2;}
  .gallery-grid .g3{grid-column:3/4; grid-row:2/3;}
  .gallery-grid .g4{grid-column:4/5; grid-row:2/3;}
  .g-caption{
    position:absolute;
    bottom:0;left:0;right:0;
    padding:16px;
    background:linear-gradient(to top, rgba(39,49,79,0.75), transparent);
    color:var(--white);
    font-weight:600;
    font-size:0.9rem;
  }

  /* ====== TESTIMONI ====== */
  .testimoni-wrap{
    margin-top:46px;
    position:relative;
  }
  .testi-track{
    display:flex;
    gap:24px;
    overflow-x:auto;
    scroll-snap-type:x mandatory;
    padding-bottom:10px;
    scrollbar-width:none;
  }
  .testi-track::-webkit-scrollbar{display:none;}
  .testi-track .testi-card{scroll-snap-stop:always;}
  .testi-dots{
    display:none;
    justify-content:center;
    gap:8px;
    margin-top:18px;
  }
  .testi-dots span{
    width:8px;height:8px;
    border-radius:50%;
    background:rgba(39,49,79,0.18);
    transition:background 0.25s ease, transform 0.25s ease;
  }
  .testi-dots span.active{
    background:var(--coral);
    transform:scale(1.3);
  }
  .testi-card{
    flex:0 0 320px;
    scroll-snap-align:start;
    background:var(--white);
    border-radius:var(--radius-md);
    padding:30px;
    box-shadow:var(--shadow-soft);
    position:relative;
  }
  .testi-quote{
    font-size:2.4rem;
    color:var(--honey);
    font-family:var(--font-display);
    line-height:1;
    margin-bottom:10px;
  }
  .testi-card p.text{
    color:var(--navy-soft);
    font-size:0.95rem;
    line-height:1.7;
    margin-bottom:20px;
    font-style:italic;
  }
  .testi-author{
    display:flex;
    align-items:center;
    gap:12px;
  }
  .testi-avatar{
    width:44px;height:44px;
    border-radius:50%;
    background:var(--mint);
    display:flex;align-items:center;justify-content:center;
    font-family:var(--font-display);
    font-weight:600;
    color:var(--navy);
  }
  .testi-author strong{display:block; font-size:0.92rem; color:var(--navy);}
  .testi-author span{font-size:0.78rem; color:var(--navy-soft);}

  /* ====== CONTACT ====== */
  .contact-box{
    background:var(--navy);
    border-radius:var(--radius-lg);
    padding:60px;
    color:var(--cream);
    display:grid;
    grid-template-columns:1fr 1fr;
    gap:50px;
    position:relative;
    overflow:hidden;
  }
  .contact-box::before{
    content:'';
    position:absolute;
    bottom:-100px;right:-80px;
    width:260px;height:260px;
    border-radius:50%;
    background:var(--honey);
    opacity:0.15;
  }
  .contact-info .section-tag{
    background:rgba(255,255,255,0.08);
    color:var(--honey);
  }
  .contact-info h2{
    font-family:var(--font-display);
    font-size:clamp(1.8rem,3vw,2.4rem);
    margin-bottom:14px;
  }
  .contact-info p{
    color:#C9CEE0;
    line-height:1.8;
    margin-bottom:28px;
    max-width:420px;
  }
  .contact-list{
    display:flex;
    flex-direction:column;
    gap:14px;
  }
  .contact-list a, .contact-list div{
    display:flex;
    align-items:center;
    gap:12px;
    color:var(--cream);
    text-decoration:none;
    font-size:0.95rem;
    font-weight:500;
  }
  .contact-list .ic{
    width:38px;height:38px;
    border-radius:10px;
    background:rgba(255,255,255,0.08);
    display:flex;align-items:center;justify-content:center;
    font-size:1.1rem;
  }
  form.contact-form{
    background:rgba(255,255,255,0.05);
    border-radius:var(--radius-md);
    padding:30px;
    display:flex;
    flex-direction:column;
    gap:16px;
    border:1px solid rgba(255,255,255,0.08);
  }
  form.contact-form input,
  form.contact-form textarea{
    background:rgba(255,255,255,0.07);
    border:1px solid rgba(255,255,255,0.12);
    border-radius:12px;
    padding:13px 16px;
    color:var(--cream);
    font-family:var(--font-body);
    font-size:0.92rem;
    outline:none;
    transition:border-color 0.25s ease;
  }
  form.contact-form input::placeholder,
  form.contact-form textarea::placeholder{color:#8A93B5;}
  form.contact-form input:focus,
  form.contact-form textarea:focus{border-color:var(--honey);}
  form.contact-form textarea{resize:vertical; min-height:90px;}
  form.contact-form button{
    background:var(--coral);
